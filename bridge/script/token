#!/usr/bin/env bash
#
# Generate a random API token and store it as SANDBOX_API_KEY.
#
#   script/token           Write to .dev.vars (local development)
#   script/token --deploy  Write to Wrangler secrets (production)
#
set -euo pipefail
export WRANGLER_SKIP_UPDATE_CHECK=1

VARFILE=".dev.vars"
SECRET_NAME="SANDBOX_API_KEY"
PREFIX="sbx_"
# 32 bytes → 43 base64url chars (no padding)
TOKEN="${PREFIX}$(openssl rand -base64 32 | tr '+/' '-_' | tr -d '=')"

deploy=false
for arg in "$@"; do
  case "$arg" in
    --deploy) deploy=true ;;
    -h|--help)
      echo "Usage: script/token [--deploy]"
      echo ""
      echo "Generates a random API token (${PREFIX}<random>) and stores it as ${SECRET_NAME}."
      echo ""
      echo "  (default)   Writes to ${VARFILE} for local development."
      echo "  --deploy    Writes to Wrangler secrets for production."
      exit 0
      ;;
    *)
      echo "Unknown flag: $arg" >&2
      exit 1
      ;;
  esac
done

confirm() {
  printf "%s [y/N] " "$1"
  read -r answer
  case "$answer" in
    [yY]*) return 0 ;;
    *) echo "Aborted."; exit 1 ;;
  esac
}

if "$deploy"; then
  # --- Production (Wrangler secrets) ---
  if npx wrangler secret list --format=json 2>/dev/null | node -e "process.exit(JSON.parse(require('fs').readFileSync(0,'utf8').trim()||'[]').some(function(x){return x.name==='${SECRET_NAME}'})?0:1)"; then
    echo "⚠  ${SECRET_NAME} already exists in Wrangler secrets."
    confirm "Overwrite the production secret?"
  fi

  # Generate a separate token for production
  PROD_TOKEN="${PREFIX}$(openssl rand -base64 32 | tr '+/' '-_' | tr -d '=')"
  echo "$PROD_TOKEN" | npx wrangler secret put "$SECRET_NAME"
  echo "✔ ${SECRET_NAME} set in Wrangler secrets."
  echo "  ${SECRET_NAME}=${PROD_TOKEN}"
else
  # --- Local development (.dev.vars) ---
  if [ -f "$VARFILE" ] && grep -q "^${SECRET_NAME}=" "$VARFILE" 2>/dev/null; then
    existing=$(grep "^${SECRET_NAME}=" "$VARFILE" | head -1 | cut -d= -f2-)
    echo "⚠  ${SECRET_NAME} already set in ${VARFILE} (${existing:0:12}…)."
    confirm "Overwrite?"
    # Remove the old line
    sed -i.bak "/^${SECRET_NAME}=/d" "$VARFILE" && rm -f "${VARFILE}.bak"
  fi

  # Append (or create) the entry
  echo "${SECRET_NAME}=${TOKEN}" >> "$VARFILE"
  echo "✔ Written to ${VARFILE}:"
  echo "  ${SECRET_NAME}=${TOKEN:0:16}…"
fi
