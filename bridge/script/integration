#!/usr/bin/env bun

/**
 * Integration tests for the deployed Cloudflare Sandbox Bridge.
 *
 * A remote BASE_URL exercises real process and terminal resources. Without
 * BASE_URL, the script starts Wrangler with containers disabled and validates
 * routing, authentication, input validation, and API metadata only.
 */

import { spawn } from 'node:child_process';
import { mkdtemp, rm, writeFile } from 'node:fs/promises';
import { tmpdir } from 'node:os';
import { join } from 'node:path';
import { setTimeout as sleep } from 'node:timers/promises';

const REMOTE_BASE = process.env.BASE_URL?.replace(/\/$/, '');
const PORT = process.env.PORT ?? '18787';
const BASE = REMOTE_BASE ?? `http://127.0.0.1:${PORT}`;
const TOKEN = process.env.SANDBOX_API_KEY ?? '';
const DEADLINE_MS = 20_000;

interface ProcessExit {
  code: number;
  signal?: number;
  timedOut: boolean;
}

interface ProcessStatus {
  id: string;
  pid: number;
  state: 'running' | 'exited' | 'error';
  exit?: ProcessExit;
}

interface ProcessEvent {
  type: string;
  data?: string;
  cursor?: string;
  exit?: ProcessExit;
}

interface TerminalSnapshot {
  id: string;
  status: 'running' | 'exited' | 'error';
}

let sandboxId = '';
let passed = 0;
let failed = 0;
const failures: Array<{ name: string; error: Error }> = [];
const activeProcesses = new Set<string>();
const activeTerminals = new Set<string>();
const openReaders = new Set<ReadableStreamDefaultReader<Uint8Array>>();
const openSockets = new Set<WebSocket>();

function errorFrom(value: unknown): Error {
  return value instanceof Error ? value : new Error(String(value));
}

function assert(condition: boolean, message: string): asserts condition {
  if (!condition) throw new Error(message);
}

function equal(actual: unknown, expected: unknown, label: string): void {
  if (actual !== expected) {
    throw new Error(
      `${label}: expected ${JSON.stringify(expected)}, got ${JSON.stringify(actual)}`
    );
  }
}

function record(value: unknown, label: string): Record<string, unknown> {
  assert(
    typeof value === 'object' && value !== null && !Array.isArray(value),
    `${label} must be an object`
  );
  return value;
}

function stringField(value: Record<string, unknown>, key: string): string {
  const field = value[key];
  assert(typeof field === 'string', `${key} must be a string`);
  return field;
}

function numberField(value: Record<string, unknown>, key: string): number {
  const field = value[key];
  assert(typeof field === 'number', `${key} must be a number`);
  return field;
}

function authHeaders(): Record<string, string> {
  return TOKEN ? { Authorization: `Bearer ${TOKEN}` } : {};
}

async function request(path: string, init: RequestInit = {}): Promise<Response> {
  const headers = new Headers(init.headers);
  for (const [key, value] of Object.entries(authHeaders())) {
    if (!headers.has(key)) headers.set(key, value);
  }
  return fetch(`${BASE}${path}`, {
    ...init,
    headers,
    signal: init.signal ?? AbortSignal.timeout(DEADLINE_MS)
  });
}

async function requestObject(
  path: string,
  init: RequestInit = {}
): Promise<{ response: Response; body: Record<string, unknown> }> {
  const response = await request(path, init);
  const body: unknown = await response.json();
  return { response, body: record(body, path) };
}

async function test(name: string, operation: () => Promise<void>): Promise<void> {
  try {
    await operation();
    passed++;
    console.log(`  ✅ ${name}`);
  } catch (error) {
    const failure = errorFrom(error);
    failed++;
    failures.push({ name, error: failure });
    console.log(`  ❌ ${name}\n     ${failure.message}`);
  }
}

function processStatus(value: unknown): ProcessStatus {
  const body = record(value, 'process status');
  const state = stringField(body, 'state');
  assert(
    state === 'running' || state === 'exited' || state === 'error',
    `invalid process state: ${state}`
  );
  const status: ProcessStatus = {
    id: stringField(body, 'id'),
    pid: numberField(body, 'pid'),
    state
  };
  if (body.exit !== undefined) {
    const exit = record(body.exit, 'process exit');
    status.exit = {
      code: numberField(exit, 'code'),
      timedOut: exit.timedOut === true
    };
    if (typeof exit.signal === 'number') status.exit.signal = exit.signal;
  }
  return status;
}

async function launch(argv: string[]): Promise<ProcessStatus> {
  const { response, body } = await requestObject(
    `/v1/sandbox/${sandboxId}/processes`,
    {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ argv })
    }
  );
  equal(response.status, 200, 'process launch status');
  const status = processStatus(body);
  activeProcesses.add(status.id);
  return status;
}

function decodeBase64(value: string): string {
  const binary = atob(value);
  const bytes = Uint8Array.from(binary, (character) => character.charCodeAt(0));
  return new TextDecoder().decode(bytes);
}

async function readWithDeadline<T>(
  reader: ReadableStreamDefaultReader<T>,
  deadline: number
): Promise<ReadableStreamReadResult<T>> {
  const remaining = deadline - Date.now();
  if (remaining <= 0) throw new Error('stream observation timed out');
  return Promise.race([
    reader.read(),
    sleep(remaining).then(() => {
      throw new Error('stream observation timed out');
    })
  ]);
}

async function observeProcess(
  id: string,
  predicate: (events: ProcessEvent[]) => boolean
): Promise<ProcessEvent[]> {
  const response = await request(
    `/v1/sandbox/${sandboxId}/processes/${id}/logs?replay=true&follow=true`
  );
  equal(response.status, 200, 'process logs status');
  assert(response.body !== null, 'process logs response has no body');
  const reader = response.body.getReader();
  openReaders.add(reader);
  const decoder = new TextDecoder();
  const events: ProcessEvent[] = [];
  const deadline = Date.now() + DEADLINE_MS;
  let buffer = '';
  try {
    while (!predicate(events)) {
      const result = await readWithDeadline(reader, deadline);
      if (result.done) break;
      buffer += decoder.decode(result.value, { stream: true });
      for (;;) {
        const boundary = buffer.indexOf('\n\n');
        if (boundary < 0) break;
        const frame = buffer.slice(0, boundary);
        buffer = buffer.slice(boundary + 2);
        const data = frame
          .split('\n')
          .filter((line) => line.startsWith('data:'))
          .map((line) => line.slice(5).trimStart())
          .join('\n');
        if (!data) continue;
        const parsed = record(JSON.parse(data), 'process log event');
        const event: ProcessEvent = { type: stringField(parsed, 'type') };
        if (typeof parsed.data === 'string') event.data = parsed.data;
        if (typeof parsed.cursor === 'string') event.cursor = parsed.cursor;
        if (parsed.exit !== undefined) {
          const exit = record(parsed.exit, 'process log exit');
          event.exit = {
            code: numberField(exit, 'code'),
            timedOut: exit.timedOut === true
          };
          if (typeof exit.signal === 'number') event.exit.signal = exit.signal;
        }
        events.push(event);
      }
    }
    assert(predicate(events), 'process logs ended before the expected event');
    return events;
  } finally {
    await reader.cancel().catch(() => undefined);
    openReaders.delete(reader);
  }
}

async function killProcess(id: string, signal = 15): Promise<void> {
  const response = await request(
    `/v1/sandbox/${sandboxId}/processes/${id}/kill`,
    {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ signal })
    }
  );
  equal(response.status, 204, 'process kill status');
}

function terminalSnapshot(value: unknown): TerminalSnapshot {
  const body = record(value, 'terminal snapshot');
  const status = stringField(body, 'status');
  assert(
    status === 'running' || status === 'exited' || status === 'error',
    `invalid terminal status: ${status}`
  );
  return { id: stringField(body, 'id'), status };
}

async function createTerminal(argv: string[]): Promise<TerminalSnapshot> {
  const { response, body } = await requestObject(
    `/v1/sandbox/${sandboxId}/terminals`,
    {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ argv, cols: 80, rows: 24 })
    }
  );
  equal(response.status, 200, 'terminal create status');
  const snapshot = terminalSnapshot(body);
  activeTerminals.add(snapshot.id);
  return snapshot;
}

interface TerminalConnection {
  socket: WebSocket;
  output: string;
  ready: boolean;
  cursor?: string;
  terminalEvent?: 'exit' | 'error';
  failure?: Error;
}

async function connectTerminal(
  id: string,
  cursor?: string
): Promise<TerminalConnection> {
  const query = cursor ? `?cursor=${encodeURIComponent(cursor)}` : '';
  const url = `${BASE.replace(/^http/, 'ws')}/v1/sandbox/${sandboxId}/terminals/${id}/connect${query}`;
  const connection: TerminalConnection = {
    socket: new WebSocket(url, { headers: authHeaders() }),
    output: '',
    ready: false
  };
  openSockets.add(connection.socket);
  let pendingChunk = false;

  connection.socket.addEventListener('message', async (event) => {
    try {
      if (typeof event.data === 'string') {
        const message = record(JSON.parse(event.data), 'terminal control');
        const type = stringField(message, 'type');
        if (type === 'ready') {
          connection.ready = true;
          if (typeof message.cursor === 'string') {
            connection.cursor = message.cursor;
          }
        } else if (type === 'chunk') {
          pendingChunk = true;
          if (typeof message.cursor === 'string') connection.cursor = message.cursor;
        } else if (type === 'exit' || type === 'error') {
          connection.terminalEvent = type;
        }
        return;
      }
      assert(pendingChunk, 'terminal binary frame arrived without chunk control');
      pendingChunk = false;
      let bytes: Uint8Array;
      if (event.data instanceof ArrayBuffer) {
        bytes = new Uint8Array(event.data);
      } else if (ArrayBuffer.isView(event.data)) {
        bytes = new Uint8Array(
          event.data.buffer,
          event.data.byteOffset,
          event.data.byteLength
        );
      } else if (event.data instanceof Blob) {
        bytes = new Uint8Array(await event.data.arrayBuffer());
      } else {
        throw new Error('unsupported terminal WebSocket frame');
      }
      connection.output += new TextDecoder().decode(bytes);
    } catch (error) {
      connection.failure = errorFrom(error);
    }
  });
  connection.socket.addEventListener('error', () => {
    connection.failure ??= new Error('terminal WebSocket failed');
  });

  await waitUntil(
    () => connection.socket.readyState === WebSocket.OPEN,
    'terminal WebSocket open'
  );
  return connection;
}

async function waitUntil(
  predicate: () => boolean,
  label: string,
  timeout = DEADLINE_MS
): Promise<void> {
  const deadline = Date.now() + timeout;
  while (!predicate()) {
    if (Date.now() >= deadline) throw new Error(`${label} timed out`);
    await sleep(20);
  }
}

async function terminateTerminal(id: string): Promise<void> {
  const response = await request(
    `/v1/sandbox/${sandboxId}/terminals/${id}/terminate`,
    { method: 'POST' }
  );
  equal(response.status, 204, 'terminal terminate status');
}

async function createSandbox(): Promise<string> {
  const { response, body } = await requestObject('/v1/sandbox', {
    method: 'POST'
  });
  equal(response.status, 200, 'sandbox create status');
  return stringField(body, 'id');
}

async function destroySandbox(): Promise<void> {
  if (!sandboxId) return;
  await request(`/v1/sandbox/${sandboxId}`, { method: 'DELETE' }).catch(
    () => undefined
  );
}

interface LocalServer {
  child: ReturnType<typeof spawn>;
  cleanup(): Promise<void>;
}

async function startServer(): Promise<LocalServer> {
  const args = ['wrangler', 'dev', '--port', PORT, '--enable-containers=false'];
  const envDirectory = TOKEN
    ? await mkdtemp(join(tmpdir(), 'sandbox-bridge-integration-'))
    : undefined;
  if (envDirectory) {
    const envFile = join(envDirectory, '.env');
    await writeFile(envFile, `SANDBOX_API_KEY=${JSON.stringify(TOKEN)}\n`, {
      mode: 0o600
    });
    args.push('--env-file', envFile);
  }

  const child = spawn('npx', args, {
    cwd: new URL('../worker', import.meta.url).pathname,
    env: {
      ...process.env,
      WRANGLER_SKIP_UPDATE_CHECK: '1'
    },
    stdio: ['ignore', 'pipe', 'pipe']
  });
  let output = '';
  child.stdout?.on('data', (data: Buffer) => (output += data.toString()));
  child.stderr?.on('data', (data: Buffer) => (output += data.toString()));
  try {
    await waitUntil(() => output.includes('Ready on'), 'Wrangler startup', 30_000);
  } catch (error) {
    child.kill('SIGTERM');
    if (envDirectory) await rm(envDirectory, { recursive: true, force: true });
    throw error;
  }
  return {
    child,
    cleanup: async () => {
      if (envDirectory) await rm(envDirectory, { recursive: true, force: true });
    }
  };
}

async function runCommonTests(): Promise<void> {
  console.log('\n📋 Bridge routing and validation');
  await test('health endpoint is available', async () => {
    const { response, body } = await requestObject('/health');
    equal(response.status, 200, 'health status');
    equal(body.ok, true, 'health body');
  });
  await test('removed execution routes return 404', async () => {
    for (const [method, path] of [
      ['POST', 'exec'],
      ['GET', 'pty'],
      ['POST', 'session']
    ]) {
      const response = await request(`/v1/sandbox/${sandboxId}/${path}`, {
        method
      });
      equal(response.status, 404, `${method} /${path}`);
    }
  });
  await test('OpenAPI exposes only resource execution routes', async () => {
    const { response, body } = await requestObject('/v1/openapi.json');
    equal(response.status, 200, 'OpenAPI status');
    equal(body.openapi, '3.1.0', 'OpenAPI version');
    const paths = record(body.paths, 'OpenAPI paths');
    assert(paths['/v1/sandbox/{id}/processes'] !== undefined, 'missing process path');
    assert(paths['/v1/sandbox/{id}/terminals'] !== undefined, 'missing terminal path');
    assert(paths['/v1/sandbox/{id}/exec'] === undefined, 'obsolete exec path present');
    assert(paths['/v1/sandbox/{id}/pty'] === undefined, 'obsolete pty path present');
    assert(paths['/v1/sandbox/{id}/session'] === undefined, 'obsolete session path present');
  });
  if (TOKEN) {
    await test('authentication rejects missing and incorrect credentials', async () => {
      const processPath = `${BASE}/v1/sandbox/${sandboxId}/processes`;
      equal((await fetch(processPath)).status, 401, 'missing process auth');
      equal(
        (await fetch(processPath, { headers: { Authorization: 'Bearer wrong' } })).status,
        401,
        'incorrect process auth'
      );
      equal((await fetch(`${BASE}/v1/openapi.json`)).status, 401, 'missing OpenAPI auth');
      equal(
        (await fetch(`${BASE}/v1/openapi.json`, { headers: authHeaders() })).status,
        200,
        'valid OpenAPI auth'
      );
    });
  }
}

async function runRemoteTests(): Promise<void> {
  console.log('\n📋 Deployed process resources');
  await test('resource routes reject unsafe input', async () => {
    const invalidProcess = await requestObject(
      `/v1/sandbox/${sandboxId}/processes`,
      {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ argv: [] })
      }
    );
    equal(invalidProcess.response.status, 400, 'invalid process status');
    equal(invalidProcess.body.code, 'invalid_request', 'invalid process code');

    const file = await request(`/v1/sandbox/${sandboxId}/file/tmp/secret`);
    equal(file.status, 403, 'file traversal status');
    const persist = await request(
      `/v1/sandbox/${sandboxId}/persist?excludes=../secret`,
      { method: 'POST' }
    );
    equal(persist.status, 400, 'persist exclusion status');
    const hydrate = await request(`/v1/sandbox/${sandboxId}/hydrate`, {
      method: 'POST',
      body: new Uint8Array(0)
    });
    equal(hydrate.status, 400, 'empty hydrate status');
    const mount = await request(`/v1/sandbox/${sandboxId}/mount`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ mountPath: 'relative', options: {} })
    });
    equal(mount.status, 400, 'mount validation status');
  });

  await test('captures process output and numeric exit status', async () => {
    const process = await launch([
      'sh',
      '-lc',
      'printf out; printf err >&2; exit 7'
    ]);
    const events = await observeProcess(process.id, (items) =>
      items.some((event) => event.type === 'terminal')
    );
    const stdout = events
      .flatMap((event) =>
        event.type === 'stdout' && event.data !== undefined
          ? [decodeBase64(event.data)]
          : []
      )
      .join('');
    const stderr = events
      .flatMap((event) =>
        event.type === 'stderr' && event.data !== undefined
          ? [decodeBase64(event.data)]
          : []
      )
      .join('');
    equal(stdout, 'out', 'stdout');
    equal(stderr, 'err', 'stderr');
    const terminal = events.find((event) => event.type === 'terminal');
    equal(terminal?.exit?.code, 7, 'exit code');
    equal(terminal?.exit?.timedOut, false, 'timedOut');

    const fetched = await requestObject(
      `/v1/sandbox/${sandboxId}/processes/${process.id}`
    );
    equal(processStatus(fetched.body).id, process.id, 'fetched process ID');
    const listed = await request(`/v1/sandbox/${sandboxId}/processes`);
    const listBody: unknown = await listed.json();
    assert(Array.isArray(listBody), 'process list must be an array');
    assert(
      listBody.some((item) => processStatus(item).id === process.id),
      'launched process missing from list'
    );
    activeProcesses.delete(process.id);
  });

  await test('log cancellation leaves the process running', async () => {
    const process = await launch(['sh', '-lc', 'echo ready; sleep 300']);
    const events = await observeProcess(process.id, (items) =>
      items.some(
        (event) =>
          event.type === 'stdout' &&
          event.data !== undefined &&
          decodeBase64(event.data).includes('ready')
      )
    );
    assert(events.length > 0, 'ready output not observed');
    const fetched = await requestObject(
      `/v1/sandbox/${sandboxId}/processes/${process.id}`
    );
    equal(processStatus(fetched.body).state, 'running', 'process state');
    await killProcess(process.id);
    const terminal = await observeProcess(process.id, (items) =>
      items.some((event) => event.type === 'terminal')
    );
    assert(
      terminal.some((event) => event.type === 'terminal'),
      'kill did not produce terminal event'
    );
    activeProcesses.delete(process.id);
  });

  console.log('\n📋 Deployed terminal resources');
  await test('terminal exchanges binary input and output', async () => {
    const terminal = await createTerminal([
      'sh',
      '-lc',
      'printf ready; read line; printf "received:%s" "$line"'
    ]);
    const connection = await connectTerminal(terminal.id);
    await waitUntil(
      () => connection.output.includes('ready') || connection.failure !== undefined,
      'terminal ready output'
    );
    if (connection.failure) throw connection.failure;
    connection.socket.send(new TextEncoder().encode('hello\n'));
    await waitUntil(
      () =>
        connection.output.includes('received:hello') ||
        connection.failure !== undefined,
      'terminal response output'
    );
    if (connection.failure) throw connection.failure;
    equal(connection.output.includes('ready'), true, 'terminal ready output');
    connection.socket.close();
    openSockets.delete(connection.socket);
    activeTerminals.delete(terminal.id);
  });

  await test('terminal observation closes without termination', async () => {
    const terminal = await createTerminal([
      'sh',
      '-lc',
      'printf ready; sleep 300'
    ]);
    const first = await connectTerminal(terminal.id);
    await waitUntil(
      () => first.output.includes('ready') || first.failure !== undefined,
      'first terminal ready output'
    );
    if (first.failure) throw first.failure;
    first.socket.close();
    await waitUntil(
      () => first.socket.readyState === WebSocket.CLOSED,
      'first terminal observation close'
    );
    openSockets.delete(first.socket);

    const fetched = await requestObject(
      `/v1/sandbox/${sandboxId}/terminals/${terminal.id}`
    );
    equal(terminalSnapshot(fetched.body).status, 'running', 'terminal state');

    const second = await connectTerminal(terminal.id, first.cursor);
    await waitUntil(
      () => second.ready || second.failure !== undefined,
      'reconnected terminal ready control'
    );
    if (second.failure) throw second.failure;
    await terminateTerminal(terminal.id);
    await waitUntil(
      () => second.terminalEvent !== undefined || second.failure !== undefined,
      'terminal exit control'
    );
    if (second.failure) throw second.failure;
    assert(
      second.terminalEvent === 'exit' || second.terminalEvent === 'error',
      'explicit terminate did not produce a terminal event'
    );
    second.socket.close();
    openSockets.delete(second.socket);
    activeTerminals.delete(terminal.id);
  });

  console.log('\n📋 Deployed workspace lifecycle');
  await test('file and workspace archive round trip', async () => {
    const marker = `bridge-${crypto.randomUUID()}`;
    const filePath = `/v1/sandbox/${sandboxId}/file/workspace/integration.txt`;
    equal(
      (
        await request(filePath, {
          method: 'PUT',
          body: new TextEncoder().encode(marker)
        })
      ).status,
      200,
      'file write status'
    );
    equal(await (await request(filePath)).text(), marker, 'file content');

    const persisted = await request(`/v1/sandbox/${sandboxId}/persist`, {
      method: 'POST'
    });
    equal(persisted.status, 200, 'persist status');
    const archive = await persisted.arrayBuffer();
    assert(archive.byteLength > 0, 'persist archive must not be empty');
    const hydrated = await request(`/v1/sandbox/${sandboxId}/hydrate`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/octet-stream' },
      body: archive
    });
    equal(hydrated.status, 200, 'hydrate status');
  });
}

async function cleanup(): Promise<void> {
  for (const reader of openReaders) await reader.cancel().catch(() => undefined);
  for (const socket of openSockets) socket.close();
  for (const id of activeProcesses) await killProcess(id).catch(() => undefined);
  for (const id of activeTerminals)
    await terminateTerminal(id).catch(() => undefined);
  await destroySandbox();
}

async function main(): Promise<void> {
  if (process.argv.includes('--help') || process.argv.includes('-h')) {
    console.log(`Usage: bridge/script/integration\n\nBASE_URL selects a deployed bridge. SANDBOX_API_KEY supplies bearer auth.`);
    return;
  }

  let server: LocalServer | undefined;
  try {
    if (!REMOTE_BASE) server = await startServer();
    console.log(`🌐 Testing ${BASE}${TOKEN ? ' with authentication' : ''}`);
    sandboxId = await createSandbox();
    await runCommonTests();
    if (REMOTE_BASE) await runRemoteTests();
  } finally {
    await cleanup();
    if (server) {
      server.child.kill('SIGTERM');
      await sleep(500);
      if (!server.child.killed) server.child.kill('SIGKILL');
      await server.cleanup();
    }
  }

  console.log(`\n${'─'.repeat(50)}\n  Results: ${passed} passed, ${failed} failed`);
  for (const failure of failures) {
    console.log(`  ❌ ${failure.name}\n     ${failure.error.message}`);
  }
  if (failed > 0) process.exitCode = 1;
}

await main().catch((error) => {
  console.error('Fatal error:', errorFrom(error));
  process.exitCode = 2;
});
