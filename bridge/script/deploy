#!/usr/bin/env bash
#
# Deploy the cloudflare-sandbox-bridge worker.
#
#   script/deploy
#
# Steps:
#   1. Install dependencies
#   2. Verify Wrangler authentication
#   3. Ensure SANDBOX_API_KEY secret exists (or create one)
#   4. Deploy via wrangler
#   5. Health-check the live endpoint
#   6. Print connection details for downstream consumers
#
set -euo pipefail
export WRANGLER_SKIP_UPDATE_CHECK=1

SECRET_NAME="SANDBOX_API_KEY"
PREFIX="sbx_"
WORKER_NAME="cloudflare-sandbox-bridge"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

step()    { printf "\n\033[1;34m→ %s\033[0m\n" "$1"; }
ok()      { printf "\033[1;32m✔ %s\033[0m\n" "$1"; }
warn()    { printf "\033[1;33m⚠  %s\033[0m\n" "$1"; }
fail()    { printf "\033[1;31m✖ %s\033[0m\n" "$1" >&2; exit 1; }

confirm() {
  printf "%s [y/N] " "$1"
  read -r answer
  case "$answer" in
    [yY]*) return 0 ;;
    *) echo "Aborted."; exit 1 ;;
  esac
}

# ---------------------------------------------------------------------------
# 1. Dependencies
# ---------------------------------------------------------------------------

step "Installing dependencies"
npm install --no-fund --no-audit
ok "Dependencies installed"

# ---------------------------------------------------------------------------
# 2. Wrangler auth
# ---------------------------------------------------------------------------

step "Checking Wrangler authentication"
if ! npx wrangler whoami --json >/dev/null 2>&1; then
  warn "Not logged in to Wrangler."
  confirm "Run 'wrangler login' now?"
  npx wrangler login
fi
whoami_json=$(npx wrangler whoami --json 2>/dev/null || true)
whoami_email=$(echo "$whoami_json" | node -p 'JSON.parse(require("fs").readFileSync(0,"utf8")).email || "unknown"' 2>/dev/null || echo "unknown")

# Show the target account. If CLOUDFLARE_ACCOUNT_ID is set, find its name;
# otherwise show all available accounts so the user knows what wrangler will prompt for.
if [ -n "${CLOUDFLARE_ACCOUNT_ID:-}" ]; then
  whoami_account=$(echo "$whoami_json" | node -p "var a=JSON.parse(require('fs').readFileSync(0,'utf8')).accounts||[]; var m=a.find(x=>x.id==='${CLOUDFLARE_ACCOUNT_ID}'); m?m.name:'unknown (${CLOUDFLARE_ACCOUNT_ID})';" 2>/dev/null || echo "unknown")
  ok "Authenticated as ${whoami_email}, deploying to ${whoami_account}"
else
  whoami_accounts=$(echo "$whoami_json" | node -p 'JSON.parse(require("fs").readFileSync(0,"utf8")).accounts.map(a=>a.name).join(", ")' 2>/dev/null || echo "unknown")
  ok "Authenticated as ${whoami_email} (accounts: ${whoami_accounts})"
  warn "CLOUDFLARE_ACCOUNT_ID not set — wrangler will prompt for account selection."
fi

# ---------------------------------------------------------------------------
# 3. SANDBOX_API_KEY secret
# ---------------------------------------------------------------------------

step "Checking ${SECRET_NAME} secret"

secret_exists=false
secret_json=$(npx wrangler secret list --format=json 2>/dev/null || echo "[]")
if echo "$secret_json" | node -p "JSON.parse(require('fs').readFileSync(0,'utf8').trim()||'[]').some(s => s.name==='${SECRET_NAME}')" 2>/dev/null | grep -q "true"; then
  secret_exists=true
fi

GENERATED_TOKEN=""

if "$secret_exists"; then
  ok "${SECRET_NAME} already configured"
else
  warn "${SECRET_NAME} is not set in production."
  confirm "Generate and deploy a new API key?"

  GENERATED_TOKEN="${PREFIX}$(openssl rand -base64 32 | tr '+/' '-_' | tr -d '=')"
  echo "$GENERATED_TOKEN" | npx wrangler secret put "$SECRET_NAME"
  ok "${SECRET_NAME} set in Wrangler secrets"
fi

# ---------------------------------------------------------------------------
# 4. Deploy
# ---------------------------------------------------------------------------

step "Deploying ${WORKER_NAME}"
deploy_log=$(mktemp)
trap 'rm -f "$deploy_log"' EXIT
npx wrangler deploy 2>&1 | tee "$deploy_log" || fail "wrangler deploy failed."
deploy_output=$(cat "$deploy_log")

# Extract the worker URL from deploy output.
# Wrangler prints URLs on their own line, indented with spaces. Match any
# https:// URL so custom domains and routes work, not just .workers.dev.
worker_url=$(echo "$deploy_output" | grep -oE 'https://[a-zA-Z0-9._-]+[a-zA-Z0-9](/[^ ]*)?' | head -1)

# Strip any trailing route wildcard (e.g. "https://sandbox.example.com/*")
worker_url="${worker_url%/\*}"

if [ -z "$worker_url" ]; then
  warn "Could not detect worker URL from deploy output."
  printf "Enter the worker URL (e.g. https://cloudflare-sandbox-bridge.you.workers.dev): "
  read -r worker_url
  [ -z "$worker_url" ] && fail "No worker URL provided."
fi

ok "Deployed to ${worker_url}"

# ---------------------------------------------------------------------------
# 5. Health check
# ---------------------------------------------------------------------------

step "Verifying /health endpoint"

for attempt in 1 2 3; do
  if health_resp=$(curl -sf --max-time 10 "${worker_url}/health" 2>/dev/null); then
    break
  fi
  [ "$attempt" -lt 3 ] && sleep 2
done

if echo "$health_resp" | node -p 'JSON.parse(require("fs").readFileSync(0,"utf8")).ok === true' 2>/dev/null | grep -q "true"; then
  ok "Health check passed"
else
  fail "Health check failed. Response: ${health_resp:-<empty>}"
fi

# ---------------------------------------------------------------------------
# 6. Summary
# ---------------------------------------------------------------------------

step "Deployment complete"

echo ""
echo "Add these to your application environment:"
echo ""
echo "  SANDBOX_API_URL=${worker_url}"

if [ -n "$GENERATED_TOKEN" ]; then
  echo "  SANDBOX_API_KEY=${GENERATED_TOKEN}"
else
  echo "  SANDBOX_API_KEY=<your existing token>"
fi

# Build the token to use in the curl example
if [ -n "$GENERATED_TOKEN" ]; then
  example_token="$GENERATED_TOKEN"
else
  example_token="\$SANDBOX_API_KEY"
fi

echo ""
echo "Test with:"
echo ""
cat <<EOF
  curl -X POST ${worker_url}/v1/sandbox/test/exec \\
    -H "Authorization: Bearer ${example_token}" \\
    -H "Content-Type: application/json" \\
    -d '{"argv": ["sh", "-lc", "echo hello world"], "timeout_ms": 10000}'
EOF
echo ""
