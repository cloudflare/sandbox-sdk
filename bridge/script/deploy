#!/usr/bin/env bash
#
# Deploy the cloudflare-sandbox-bridge worker.
#
#   script/deploy
#
# Steps:
#   1. Install dependencies
#   2. Verify Wrangler authentication
#   3. Ensure SANDBOX_API_KEY secret exists (or create one)
#   4. Deploy via wrangler
#   5. Health-check the live endpoint
#   6. Print connection details for downstream consumers
#
set -euo pipefail
export WRANGLER_SKIP_UPDATE_CHECK=1

SECRET_NAME="SANDBOX_API_KEY"
PREFIX="sbx_"
WORKER_NAME="cloudflare-sandbox-bridge"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

step()    { printf "\n\033[1;34m→ %s\033[0m\n" "$1"; }
ok()      { printf "\033[1;32m✔ %s\033[0m\n" "$1"; }
warn()    { printf "\033[1;33m⚠  %s\033[0m\n" "$1"; }
fail()    { printf "\033[1;31m✖ %s\033[0m\n" "$1" >&2; exit 1; }

confirm() {
  printf "%s [y/N] " "$1"
  read -r answer
  case "$answer" in
    [yY]*) return 0 ;;
    *) echo "Aborted."; exit 1 ;;
  esac
}

# ---------------------------------------------------------------------------
# 1. Dependencies
# ---------------------------------------------------------------------------

step "Installing dependencies"
npm ci --no-fund --no-audit --silent
ok "Dependencies installed"

# ---------------------------------------------------------------------------
# 2. Wrangler auth
# ---------------------------------------------------------------------------

step "Checking Wrangler authentication"
if ! npx wrangler whoami --json >/dev/null 2>&1; then
  warn "Not logged in to Wrangler."
  confirm "Run 'wrangler login' now?"
  npx wrangler login
fi
whoami_ident=$(npx wrangler whoami --json 2>/dev/null \
  | node -e 'var d=JSON.parse(require("fs").readFileSync(0,"utf8")); var e=d.user&&d.user.email||"unknown"; var a=d.accounts&&d.accounts[0]&&d.accounts[0].name||"unknown"; process.stdout.write(e+" ("+a+")")' 2>/dev/null)
ok "Authenticated as ${whoami_ident:-unknown}"

# ---------------------------------------------------------------------------
# 3. SANDBOX_API_KEY secret
# ---------------------------------------------------------------------------

step "Checking ${SECRET_NAME} secret"

secret_exists=false
if npx wrangler secret list --format=json 2>/dev/null | node -e "process.exit(JSON.parse(require('fs').readFileSync(0,'utf8').trim()||'[]').some(function(x){return x.name==='${SECRET_NAME}'})?0:1)"; then
  secret_exists=true
fi

GENERATED_TOKEN=""

if "$secret_exists"; then
  ok "${SECRET_NAME} already configured"
else
  warn "${SECRET_NAME} is not set in production."
  confirm "Generate and deploy a new API key?"

  GENERATED_TOKEN="${PREFIX}$(openssl rand -base64 32 | tr '+/' '-_' | tr -d '=')"
  echo "$GENERATED_TOKEN" | npx wrangler secret put "$SECRET_NAME"
  ok "${SECRET_NAME} set in Wrangler secrets"
fi

# ---------------------------------------------------------------------------
# 4. Deploy
# ---------------------------------------------------------------------------

step "Deploying ${WORKER_NAME}"
deploy_output=$(npx wrangler deploy 2>&1)
echo "$deploy_output"

# Extract the worker URL from deploy output (e.g. https://cloudflare-sandbox-bridge.user.workers.dev)
worker_url=$(echo "$deploy_output" | grep -oE 'https://[a-zA-Z0-9._-]+\.workers\.dev' | head -1)

if [ -z "$worker_url" ]; then
  fail "Could not determine worker URL from deploy output."
fi

ok "Deployed to ${worker_url}"

# ---------------------------------------------------------------------------
# 5. Health check
# ---------------------------------------------------------------------------

step "Verifying /health endpoint"

for attempt in 1 2 3; do
  if health_resp=$(curl -sf --max-time 10 "${worker_url}/health" 2>/dev/null); then
    break
  fi
  [ "$attempt" -lt 3 ] && sleep 2
done

if echo "$health_resp" | grep -q '"ok"'; then
  ok "Health check passed"
else
  fail "Health check failed. Response: ${health_resp:-<empty>}"
fi

# ---------------------------------------------------------------------------
# 6. Summary
# ---------------------------------------------------------------------------

step "Deployment complete"

echo ""
echo "Add these to your application environment:"
echo ""
echo "  SANDBOX_API_URL=${worker_url}"

if [ -n "$GENERATED_TOKEN" ]; then
  echo "  SANDBOX_API_KEY=${GENERATED_TOKEN}"
else
  echo "  SANDBOX_API_KEY=<your existing token>"
fi

# Build the token to use in the curl example
if [ -n "$GENERATED_TOKEN" ]; then
  example_token="$GENERATED_TOKEN"
else
  example_token="\$SANDBOX_API_KEY"
fi

echo ""
echo "Test with:"
echo ""
cat <<EOF
  curl -X POST ${worker_url}/sandbox/test/exec \\
    -H "Authorization: Bearer ${example_token}" \\
    -H "Content-Type: application/json" \\
    -d '{"argv": ["sh", "-lc", "echo hello world"], "timeout_ms": 10000}'
EOF
echo ""
