{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "types": ["node", "@cloudflare/workers-types"],
    "lib": ["ES2024"],
    "resolveJsonModule": true,
    "paths": {
      "@repo/shared/backup": ["../shared/src/backup.ts"],
      // Alias the public authoring subpaths back to source so extensions
      // living outside `packages/sandbox/src/` can import
      // `@cloudflare/sandbox/extensions` / `/sidecar` / `/errors` and still
      // typecheck against the current tree (dist may not exist yet).
      "@cloudflare/sandbox/extensions": ["src/extensions/index.ts"],
      "@cloudflare/sandbox/sidecar": ["src/sidecar/index.ts"],
      "@cloudflare/sandbox/errors": ["src/errors/index.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "../../extensions/*/src/**/*.ts",
    "../../extensions/*/tests/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "../../extensions/interpreter/src/sidecar/**/*.ts",
    "../../extensions/interpreter/build.ts"
  ]
}
