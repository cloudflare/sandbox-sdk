{
  "name": "sandbox-test",
  // Entry is the eviction-test worker: it re-exports the SDK worker surface
  // (so the Sandbox container binding resolves) plus the OpenCodeFixture DO that
  // the DO-eviction test drives via its namespace binding.
  "main": "opencode/eviction-worker.ts",
  "compatibility_date": "2025-05-06",
  "compatibility_flags": ["nodejs_compat"],

  "observability": {
    "enabled": true
  },

  "containers": [
    {
      "class_name": "Sandbox",
      "image": "../Dockerfile",
      "name": "sandbox",
      "max_instances": 1
    }
  ],

  "durable_objects": {
    "bindings": [
      {
        "class_name": "Sandbox",
        "name": "Sandbox"
      },
      {
        "class_name": "OpenCodeFixture",
        "name": "OpenCodeFixture"
      }
    ]
  },

  "migrations": [
    {
      "new_sqlite_classes": ["Sandbox"],
      "tag": "v1"
    },
    {
      "new_sqlite_classes": ["OpenCodeFixture"],
      "tag": "v2"
    }
  ]
}
